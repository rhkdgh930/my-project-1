          "legendFormat": "fail {{eventType}}"
        },
        {
          "expr": "sum(increase(outbox_retry_request_total[5m])) by (mode)",
          "legendFormat": "retry {{mode}}"
        }
      ],
      "title": "Outbox",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
