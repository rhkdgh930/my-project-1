          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_sum[1m])) / clamp_min(sum(rate(http_server_requests_seconds_count[1m])), 1)",
          "legendFormat": "avg latency"
        }
      ],
      "title": "HTTP Average Latency",
      "type": "timeseries"
    },
    {
      "datasource": {
